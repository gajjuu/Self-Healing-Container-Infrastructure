# .env.example
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Optional: Slack Incoming Webhook URL for alert notifications.
# Create one at: https://api.slack.com/messaging/webhooks
# Leave blank to disable Slack alerts (the healer will still function).
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Healer tuning (these match the docker-compose defaults — override here if needed)
# CHECK_INTERVAL=15
# FAILURE_THRESHOLD=3
# REQUEST_TIMEOUT=5
